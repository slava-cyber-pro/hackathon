{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"budgetsphere-backend\"}[1m])) by (handler, method)",
          "legendFormat": "{{method}} {{handler}}"
        }
      ]
    },
    {
      "title": "Response Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"budgetsphere-backend\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"budgetsphere-backend\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"budgetsphere-backend\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"budgetsphere-backend\", status=~\"4..|5..\"}[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Requests In Progress",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress{job=\"budgetsphere-backend\"})",
          "legendFormat": "in-flight"
        }
      ]
    },
    {
      "title": "Response Size (avg bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "rate(http_response_size_bytes_sum{job=\"budgetsphere-backend\"}[5m]) / rate(http_response_size_bytes_count{job=\"budgetsphere-backend\"}[5m])",
          "legendFormat": "avg response"
        }
      ]
    },
    {
      "title": "Latency by Endpoint (p95)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"budgetsphere-backend\"}[5m])) by (le, handler))",
          "legendFormat": "{{handler}}",
          "format": "table",
          "instant": true
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["budgetsphere", "api", "performance"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "BudgetSphere — API Performance",
  "uid": "budgetsphere-api-perf"
}
